# Application Settings
APP_NAME=JobBot
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
# SQLite (development - will be deprecated)
DATABASE_URL=sqlite:///./data/database/job_bot.db
DATABASE_ECHO=False

# PostgreSQL Configuration (production - REQUIRED for 1000+ users)
# All credentials must be set via environment variables for security
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=your-secure-password-here-min-12-chars
POSTGRES_DATABASE=jobbot

# PostgreSQL SSL Configuration
POSTGRES_SSL_MODE=prefer
# Optional: SSL certificate paths for verify-ca/verify-full modes
# POSTGRES_SSL_CERT=/path/to/client-cert.pem
# POSTGRES_SSL_KEY=/path/to/client-key.pem
# POSTGRES_SSL_ROOT_CERT=/path/to/ca-cert.pem

# PostgreSQL Connection Pooling (optimized for 1000 concurrent users)
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=30
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600
POSTGRES_POOL_PRE_PING=True

# PostgreSQL Timeouts
POSTGRES_CONNECT_TIMEOUT=10
POSTGRES_STATEMENT_TIMEOUT=30000

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_PATH=config/credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TOKEN_PATH=config/token.json

# ATS API Settings
GREENHOUSE_API_KEY=
GREENHOUSE_API_VERSION=v1
LEVER_API_KEY=
ASHBY_API_KEY=

# LLM Settings (Optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-sonnet-20240229

# Browser Automation
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_TIMEOUT=30000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/job_bot.log

# Cache Settings
CACHE_TTL=3600
ENABLE_CACHE=True

# Job Fetching
FETCH_INTERVAL_HOURS=6
MAX_JOBS_PER_SOURCE=100

# User Preferences (Default values)
DEFAULT_LOCATION=New York
DEFAULT_REMOTE=True
TARGET_ROLES=backend,infrastructure,platform,ml_infra

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60